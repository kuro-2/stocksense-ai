generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  analyses    Analysis[]
  watchlist   WatchlistItem[]
  portfolio   Portfolio?
  alerts      PriceAlert[]
  sessions    UserSession[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model StockCache {
  id          String   @id @default(uuid())
  symbol      String
  exchange    String   @default("NSE")
  dataType    String
  data        Json
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime

  @@unique([symbol, exchange, dataType])
  @@index([symbol])
  @@index([expiresAt])
  @@map("stock_cache")
}

model Analysis {
  id                String   @id @default(uuid())
  userId            String?
  symbol            String
  stockName         String
  exchange          String   @default("NSE")
  sector            String?
  marketCapCategory String?

  priceAtAnalysis   Float
  changePercent     Float

  recommendation    String
  confidence        String
  targetPrice       Float
  stopLoss          Float
  timeframe         String

  summary           String
  reasoning         String
  risks             String[]

  trend             String
  rsiValue          Float?
  support           Float?
  resistance        Float?

  foStrategy        String
  foTips            String?
  foExpiry          String?
  foStrike          Float?

  newsHighlights    String[]

  rawAiResponse     Json?

  generatedAt       DateTime @default(now())

  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([symbol])
  @@index([generatedAt])
  @@map("analyses")
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  stockName String
  exchange  String   @default("NSE")
  addedAt   DateTime @default(now())
  notes     String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
  @@map("watchlist_items")
}

model Portfolio {
  id            String   @id @default(uuid())
  userId        String   @unique
  virtualCash   Float    @default(1000000)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades        Trade[]
  positions     Position[]

  @@map("portfolios")
}

model Trade {
  id             String   @id @default(uuid())
  portfolioId    String
  symbol         String
  stockName      String
  exchange       String   @default("NSE")
  tradeType      String
  instrumentType String   @default("EQUITY")
  quantity       Int
  price          Float
  totalValue     Float
  notes          String?
  executedAt     DateTime @default(now())

  optionType     String?
  strikePrice    Float?
  expiry         String?
  lotSize        Int?

  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([symbol])
  @@map("trades")
}

model Position {
  id              String   @id @default(uuid())
  portfolioId     String
  symbol          String
  stockName       String
  exchange        String   @default("NSE")
  instrumentType  String   @default("EQUITY")
  quantity        Int
  averageCost     Float
  currentPrice    Float
  unrealizedPnL   Float
  realizedPnL     Float    @default(0)
  updatedAt       DateTime @updatedAt

  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol, instrumentType])
  @@index([portfolioId])
  @@map("positions")
}

model PriceAlert {
  id          String   @id @default(uuid())
  userId      String
  symbol      String
  stockName   String
  condition   String
  targetPrice Float
  isActive    Boolean  @default(true)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol, isActive])
  @@map("price_alerts")
}
